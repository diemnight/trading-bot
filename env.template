# Copy this to .env for LOCAL use. The .env file is gitignored.
# In cloud routines, set these as environment variables ON THE ROUTINE
# itself — do NOT create a .env file in the cloud.

# --- Alpaca (PAPER trading by default) ---
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_paper_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_here

# --- Perplexity (research) — OPTIONAL ---
# If unset, scripts/perplexity.sh exits 3 and the agent falls back to WebSearch.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# --- Notifications (Discord or Slack incoming webhook) — OPTIONAL ---
# Configured channel: Slack (incoming webhook -> #trading-bot).
# Set NOTIFY_WEBHOOK_URL to your https://hooks.slack.com/services/... URL.
# If NOTIFY_WEBHOOK_URL is unset, alerts append to NOTIFICATIONS.md in the repo.
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_TYPE=slack
